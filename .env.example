# ANTHROPIC_API_KEY=

# Optional: primary webhook for CRM or general automation workflow.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# Optional: explicit fan-out destinations for CRM and WhatsApp flows.
LEAD_CRM_WEBHOOK_URL=
LEAD_CRM_WEBHOOK_SECRET=
LEAD_WHATSAPP_WEBHOOK_URL=
LEAD_WHATSAPP_WEBHOOK_SECRET=
