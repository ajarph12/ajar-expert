AI_CHAT_PROVIDER=openai
AI_CHAT_MODEL=gpt-5
OPENAI_API_KEY=

# If you prefer Gemini, switch provider and fill this instead:
# AI_CHAT_PROVIDER=google
# AI_CHAT_MODEL=gemini-2.5-flash
# GOOGLE_GENERATIVE_AI_API_KEY=

# If you prefer Anthropic, switch provider and fill this instead:
